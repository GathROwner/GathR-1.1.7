{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "types" // <-- Add your custom types folder here
  ],
  "exclude": [
    "**/*Copy*.ts",
    "**/*Copy*.tsx",
    "**/*copy*.ts",
    "**/*copy*.tsx"
  ]
}
